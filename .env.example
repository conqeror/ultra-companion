# Mapbox tokens — get yours at https://account.mapbox.com/access-tokens/
# Download token: used at build time to fetch the Mapbox SDK (needs Downloads:Read scope)
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=sk.your_download_token_here
# Access token: used at runtime for map rendering (needs default public scopes)
MAPBOX_ACCESS_TOKEN=pk.your_access_token_here

# Google Places API key — used at runtime for gas station & grocery POI data
# Get one at https://console.cloud.google.com/apis/credentials (enable Places API New)
GOOGLE_PLACES_API_KEY=your_api_key_here
