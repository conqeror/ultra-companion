{
  "name": "ultra",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:export": "expo export --platform web && node scripts/prepare-web-export.mjs",
    "web:serve": "node scripts/serve-web.mjs",
    "assets:generate": "node scripts/generate-assets.mjs",
    "db:generate": "drizzle-kit generate",
    "db:bundle": "node scripts/bundle-migrations.mjs",
    "db:migrate": "npm run db:generate && npm run db:bundle",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "postinstall": "patch-package && git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@expo/ui": "~55.0.17",
    "@react-navigation/native": "^7.1.33",
    "@rnmapbox/maps": "^10.3.2",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "2.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "expo": "~55.0.27",
    "expo-constants": "~55.0.16",
    "expo-document-picker": "~55.0.14",
    "expo-file-system": "~55.0.23",
    "expo-font": "~55.0.8",
    "expo-linking": "~55.0.16",
    "expo-location": "~55.1.11",
    "expo-network": "~55.0.15",
    "expo-router": "~55.0.16",
    "expo-splash-screen": "~55.0.22",
    "expo-sqlite": "~55.0.17",
    "fast-xml-parser": "^5.10.0",
    "lucide-react": "^1.24.0",
    "lucide-react-native": "^1.24.0",
    "mapbox-gl": "^2.15.0",
    "nativewind": "^4.2.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/mapbox-gl": "^3.4.1",
    "@types/react": "~19.2.17",
    "@types/react-dom": "~19.2.3",
    "babel-preset-expo": "~55.0.23",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.73.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2",
    "vitest": "^3.2.7"
  }
}
