{
  "name": "ultra",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "db:generate": "drizzle-kit generate",
    "db:bundle": "node scripts/bundle-migrations.mjs",
    "db:migrate": "npm run db:generate && npm run db:bundle",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "postinstall": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@rnmapbox/maps": "^10.3.0",
