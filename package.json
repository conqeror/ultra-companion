    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "expo": "~55.0.8",
    "expo-constants": "~55.0.9",
    "expo-document-picker": "~55.0.9",
    "expo-file-system": "~55.0.11",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-location": "~55.1.4",
    "expo-network": "~55.0.9",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "expo-symbols": "~55.0.5",
